# ═══════════════════════════════════════════════════
# RD-Agent Quant Optimizer - Environment Configuration
# ═══════════════════════════════════════════════════

# ──────── Required: DeepSeek API ────────
# Get your key at: https://platform.deepseek.com/api_keys
# New accounts get 5M free tokens (~$1.40 value)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ──────── Optional: Premium Model ────────
# Only needed if using 'premium' profile
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# ──────── RD-Agent Core Settings ────────
# Our patched backend with multi-model routing
BACKEND=src.model_router.PatchedLiteLLMBackend

# Default model (used by unpatched RD-Agent calls)
CHAT_MODEL=deepseek/deepseek-chat

# Embedding model (SiliconFlow free tier or OpenAI)
EMBEDDING_MODEL=text-embedding-ada-002
# SILICONFLOW_API_KEY=sk-your-siliconflow-key  # For free embeddings

# ──────── Per-Module Model Override ────────
# Uncomment to customize which model each stage uses
# SYNTHESIS_MODEL=deepseek/deepseek-reasoner
# IMPLEMENTATION_MODEL=deepseek/deepseek-chat
# ANALYSIS_MODEL=deepseek/deepseek-reasoner

# ──────── Cost Controls ────────
DAILY_BUDGET_USD=5.0

# ──────── Qlib Settings ────────
# Data provider (default: Yahoo Finance, no account needed)
QLIB_DATA_PROVIDER=yahoo

# ──────── Docker (required for RD-Agent code execution) ────────
# RD-Agent runs generated code inside Docker for safety
# Make sure Docker is installed and running
